# ============================================
# CONFIGURACIÓN RECOMENDADA PARA PRODUCCIÓN
# APIDIAN - Facturación Electrónica DIAN
# ============================================

# --- APLICACIÓN ---
APP_NAME="APIDIAN"
APP_VERSION=" v2.1"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_PORT=443
APP_URL=https://tu-dominio.com
FORCE_HTTPS=true

# --- LOGGING ---
LOG_CHANNEL=daily
LOG_LEVEL=error

# --- BASE DE DATOS ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apirestdian
DB_USERNAME=apidian_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# --- CACHE Y SESIONES ---
# Opción 1: Sin Redis (básico)
# CACHE_DRIVER=file
# SESSION_DRIVER=file
# QUEUE_CONNECTION=sync

# Opción 2: Con Redis (RECOMENDADO para mejor rendimiento)
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# --- REDIS (Recomendado para producción) ---
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# --- EMAIL ---
MAIL_DRIVER=smtp
MAIL_HOST=smtp.tu-proveedor.com
MAIL_PORT=587
MAIL_USERNAME=tu-usuario
MAIL_PASSWORD=tu-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=facturacion@tu-dominio.com
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS (Opcional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# --- CONFIGURACIÓN DEL SISTEMA ---
ALLOW_PUBLIC_DOWNLOAD=true
APPLY_SEND_CUSTOMER_CREDENTIALS=true
GRAPHIC_REPRESENTATION_TEMPLATE=2

# --- SEGURIDAD API ---
# Deshabilitar registro público en producción si no es necesario
ALLOW_PUBLIC_REGISTER=false
ENABLE_API_REGISTER=false

# Habilitar validación antes de enviar (evita duplicados)
VALIDATE_BEFORE_SENDING=true

# Guardar respuestas DIAN en BD (útil para auditoría)
SAVE_RESPONSE_DIAN_TO_DB=true

# --- PROTECCIÓN API KEY (Opcional - capa extra de seguridad) ---
USE_PROTECTION_API_KEY=false
API_KEY=GENERAR_KEY_SEGURA_AQUI

# --- RATE LIMITING (Recomendado) ---
API_RATE_LIMIT=60
API_RATE_LIMIT_MINUTES=1

# --- RENDIMIENTO (Optimización) ---
# Cache de catálogos DIAN
CATALOG_CACHE_ENABLED=true
CATALOG_CACHE_TTL=86400

# Verificación de estado DIAN
DIAN_CHECK_CACHE_TTL=30
DIAN_CHECK_TIMEOUT=5
DIAN_CONNECT_TIMEOUT=3

# Generación de PDFs
PDF_MEMORY_LIMIT=512M
PDF_TIME_LIMIT=120

# Conexiones HTTP
HTTP_TIMEOUT=30
HTTP_CONNECT_TIMEOUT=10
HTTP_RETRY_ATTEMPTS=2
